{
  "cli": {
    "version": ">= 21.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_AUTH_URL": "https://deploy-bank-api.onrender.com/api/v1/Auth",
        "EXPO_PUBLIC_API_BASE": "https://deploy-bank-api.onrender.com/api/v1",
        "EXPO_PUBLIC_BANKING_API_BASE": "https://deploy-bank-node.onrender.com/SistemaBancarioAdmin/v1",
        "EXPO_PUBLIC_API_AUTH_URL": "https://deploy-bank-api.onrender.com/api/v1",
        "EXPO_PUBLIC_API_BANKING_URL": "https://deploy-bank-node.onrender.com/SistemaBancarioAdmin/v1",
        "EXPO_PUBLIC_API_ADMIN_URL": "https://deploy-bank-api.onrender.com/api/v1/admin",
        "EXPO_PUBLIC_DEV_HOST": "192.168.1.45"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_AUTH_URL": "https://deploy-bank-api.onrender.com/api/v1/Auth",
        "EXPO_PUBLIC_API_BASE": "https://deploy-bank-api.onrender.com/api/v1",
        "EXPO_PUBLIC_BANKING_API_BASE": "https://deploy-bank-node.onrender.com/SistemaBancarioAdmin/v1",
        "EXPO_PUBLIC_API_AUTH_URL": "https://deploy-bank-api.onrender.com/api/v1",
        "EXPO_PUBLIC_API_BANKING_URL": "https://deploy-bank-node.onrender.com/SistemaBancarioAdmin/v1",
        "EXPO_PUBLIC_API_ADMIN_URL": "https://deploy-bank-api.onrender.com/api/v1/admin"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
